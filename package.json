{
  "name": "tbre-website",
  "version": "0.2.0",
  "private": true,
  "description": "Team Bath Racing Electric's official website, built with Astro and Tailwind CSS.",
  "author": "Tom Heaton <tom@tomheaton.dev> (https://tomheaton.dev)",
  "scripts": {
    "build": "astro build",
    "check": "astro check",
    "clean": "rm -rf node_modules .astro dist",
    "dev": "astro dev",
    "format": "biome format --write",
    "lint": "biome check",
    "lint:ci": "biome ci",
    "lint:fix": "biome check --fix --unsafe",
    "optimise:svg": "svgo -rf ./public -o ./public",
    "preview": "astro preview",
    "start": "astro preview",
    "typecheck": "astro sync && tsgo -b",
    "unused": "knip --cache",
    "validate:content": "tsx scripts/validate-content.ts"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/sitemap": "^3.7.3",
    "@fortawesome/free-brands-svg-icons": "^7.3.0",
    "@lucide/astro": "^1.22.0",
    "astro": "^7.0.4"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@biomejs/biome": "^2.5.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.12.2",
    "@typescript/native-preview": "7.0.0-dev.20260629.1",
    "knip": "^6.23.0",
    "svgo": "^4.0.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": "24.x",
    "pnpm": "11.x"
  }
}
